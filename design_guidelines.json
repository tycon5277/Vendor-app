{
  "design_system": {
    "identity": {
      "name": "Vendor App iOS Overhaul",
      "style": "Apple Human Interface Guidelines (iOS 17)",
      "tone": "Professional, Clean, Efficient, Trustworthy",
      "platform": "React Native (Expo)"
    },
    "colors": {
      "light": {
        "background": {
          "primary": "#FFFFFF",
          "secondary": "#F2F2F7",
          "tertiary": "#FFFFFF",
          "modal": "#FFFFFF",
          "grouped": "#F2F2F7"
        },
        "text": {
          "primary": "#000000",
          "secondary": "#3C3C4399",
          "tertiary": "#3C3C434D",
          "tint": "#007AFF",
          "inverse": "#FFFFFF"
        },
        "border": "#C6C6C8",
        "separator": "#3C3C435C",
        "primary": "#007AFF",
        "success": "#34C759",
        "warning": "#FF9500",
        "danger": "#FF3B30",
        "card": "#FFFFFF"
      },
      "dark": {
        "background": {
          "primary": "#000000",
          "secondary": "#1C1C1E",
          "tertiary": "#2C2C2E",
          "modal": "#1C1C1E",
          "grouped": "#000000"
        },
        "text": {
          "primary": "#FFFFFF",
          "secondary": "#EBEBF599",
          "tertiary": "#EBEBF54D",
          "tint": "#0A84FF",
          "inverse": "#000000"
        },
        "border": "#38383A",
        "separator": "#545458A6",
        "primary": "#0A84FF",
        "success": "#30D158",
        "warning": "#FF9F0A",
        "danger": "#FF453A",
        "card": "#1C1C1E"
      }
    },
    "typography": {
      "fontFamily": {
        "ios": "System",
        "android": "Roboto"
      },
      "styles": {
        "largeTitle": { "fontSize": 34, "fontWeight": "700", "lineHeight": 41, "letterSpacing": 0.37 },
        "title1": { "fontSize": 28, "fontWeight": "700", "lineHeight": 34, "letterSpacing": 0.36 },
        "title2": { "fontSize": 22, "fontWeight": "600", "lineHeight": 28, "letterSpacing": 0.35 },
        "title3": { "fontSize": 20, "fontWeight": "600", "lineHeight": 25, "letterSpacing": 0.38 },
        "headline": { "fontSize": 17, "fontWeight": "600", "lineHeight": 22, "letterSpacing": -0.41 },
        "body": { "fontSize": 17, "fontWeight": "400", "lineHeight": 22, "letterSpacing": -0.41 },
        "callout": { "fontSize": 16, "fontWeight": "400", "lineHeight": 21, "letterSpacing": -0.32 },
        "subhead": { "fontSize": 15, "fontWeight": "400", "lineHeight": 20, "letterSpacing": -0.24 },
        "footnote": { "fontSize": 13, "fontWeight": "400", "lineHeight": 18, "letterSpacing": -0.08 },
        "caption1": { "fontSize": 12, "fontWeight": "400", "lineHeight": 16, "letterSpacing": 0 },
        "caption2": { "fontSize": 11, "fontWeight": "400", "lineHeight": 13, "letterSpacing": 0.07 }
      }
    },
    "spacing": {
      "xs": 4,
      "s": 8,
      "m": 12,
      "l": 16,
      "xl": 20,
      "xxl": 24,
      "xxxl": 32,
      "section": 32
    },
    "borderRadius": {
      "s": 8,
      "m": 12,
      "l": 16,
      "xl": 20,
      "full": 9999
    },
    "shadows": {
      "light": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 2 },
        "shadowOpacity": 0.1,
        "shadowRadius": 8,
        "elevation": 2
      },
      "dark": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 4 },
        "shadowOpacity": 0.3,
        "shadowRadius": 10,
        "elevation": 4
      }
    }
  },
  "components": {
    "Button": {
      "base": {
        "height": 50,
        "borderRadius": 12,
        "justifyContent": "center",
        "alignItems": "center",
        "flexDirection": "row",
        "gap": 8
      },
      "primary": {
        "backgroundColor": "primary",
        "text": "inverse"
      },
      "secondary": {
        "backgroundColor": "background.secondary",
        "text": "primary"
      },
      "destructive": {
        "backgroundColor": "background.secondary",
        "text": "danger"
      },
      "ghost": {
        "backgroundColor": "transparent",
        "text": "primary"
      }
    },
    "Input": {
      "base": {
        "height": 50,
        "borderRadius": 12,
        "paddingHorizontal": 16,
        "fontSize": 17,
        "backgroundColor": "background.secondary",
        "color": "text.primary"
      }
    },
    "Card": {
      "base": {
        "backgroundColor": "background.primary",
        "borderRadius": 16,
        "padding": 16,
        "marginBottom": 16
      }
    },
    "ListItem": {
      "base": {
        "minHeight": 44,
        "flexDirection": "row",
        "alignItems": "center",
        "justifyContent": "space-between",
        "backgroundColor": "background.primary",
        "paddingHorizontal": 16,
        "paddingVertical": 12,
        "borderBottomWidth": 0.5,
        "borderColor": "separator"
      }
    },
    "Badge": {
      "base": {
        "paddingHorizontal": 10,
        "paddingVertical": 4,
        "borderRadius": 12
      },
      "text": {
        "fontSize": 12,
        "fontWeight": "600",
        "textTransform": "uppercase"
      }
    }
  },
  "navigation": {
    "header": {
      "largeTitle": true,
      "transparent": true,
      "blurEffect": "regular"
    },
    "tabBar": {
      "blurEffect": "regular",
      "activeTintColor": "primary",
      "inactiveTintColor": "text.secondary"
    }
  },
  "assets": {
    "icons": {
      "library": "@expo/vector-icons",
      "family": "Ionicons",
      "size": {
        "s": 16,
        "m": 20,
        "l": 24,
        "xl": 28
      }
    }
  },
  "copywriting": {
    "replacements": {
      "Delivery Fee": "Handling & Transportation"
    }
  },
  "instructions_to_main_agent": [
    "1. SETUP THEME CONTEXT: Create 'src/context/ThemeContext.tsx' to manage light/dark mode and provide colors globally.",
    "2. CREATE UI KIT: Implement the following components in 'src/components/ui/':",
    "   - 'Button.tsx': Supports variant (primary, secondary, destructive, ghost) and size.",
    "   - 'Input.tsx': Supports label, error, and left/right icons.",
    "   - 'Card.tsx': Simple wrapper with shadow and rounded corners.",
    "   - 'ScreenWrapper.tsx': Handles SafeAreaView and StatusBar.",
    "   - 'Typography.tsx': Components for Title1, Headline, Body, etc.",
    "   - 'ListItem.tsx': Standard iOS list row with left/right content.",
    "3. UPDATE NAVIGATION: Modify 'app/_layout.tsx' and 'app/(main)/_layout.tsx' to use the new theme colors and blur headers.",
    "4. REFACTOR SCREENS: Go through each screen in 'app/' and replace native 'View'/'Text' with your new UI Kit components.",
    "5. PRESERVE LOGIC: Do not change the business logic in 'src/store' or api calls. Only change the 'render' part of components.",
    "6. LISTS: Ensure all lists use 'FlatList' or 'SectionList' with 'ListHeaderComponent' for titles to avoid scrolling issues.",
    "7. MODALS: Use Expo Router's 'presentation: modal' for edit screens or details.",
    "8. KEYBOARD: Wrap forms in 'KeyboardAwareScrollView' (already installed).",
    "9. TESTID: Add 'testID' (React Native) prop to all interactive elements for testing."
  ],
  "universal_guidelines": [
    "Use 'StyleSheet.create' for performance, but drive values from the theme constants.",
    "Do NOT use inline styles for static properties.",
    "Ensure 44x44pt minimum touch targets.",
    "Use 'ActivityIndicator' for loading states.",
    "Respect Safe Area insets."
  ]
}